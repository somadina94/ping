{
  "name": "ping",
  "version": "1.0.0",
  "description": "PING — VPS health monitor with Express + TypeScript + Mongoose, email alerts, Docker, CI",
  "license": "MIT",
  "author": "jahbyte",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && mkdir -p dist/views && cp -r src/views dist/",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --watch --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:run:host-mongo": "docker run --rm -p ${PORT:-3000}:${PORT:-3000} --env-file .env -e DATABASE=${DOCKER_RUN_DATABASE:-mongodb://host.docker.internal:27017/ping} ping:test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pug": "^3.0.4",
    "slugify": "^1.6.6",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "@types/jest": "^29.5.14",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.6",
    "@types/html-to-text": "^9.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pug": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "babel-jest": "^29.7.0",
    "eslint": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "jest": "^29.7.0",
    "typescript-eslint": "^8.59.2"
  }
}
