NODE_ENV=development
PORT=3000
# --- Local Node (`npm run dev`): DATABASE targets Mongo on your machine.
# --- Docker dev (`npm run docker:dev`): compose overrides DATABASE to mongodb://mongo:27017/...
#    DATABASE_PASSWORD below is passed through for <password> placeholders.
# --- Production: use real Atlas/managed URI + DATABASE_PASSWORD as in README.

DATABASE=mongodb://localhost:27017/ping
# Optional: overrides DATABASE when using docker-compose.dev.yml (default is mongodb://mongo:27017/...)
# DOCKER_DATABASE=mongodb://mongo:27017/ping
DATABASE_PASSWORD=
# Use >=32 characters for NODE_ENV=staging or NODE_ENV=production
JWT_SECRET=your-256-bit-secret-change-me-min-32-chars
JWT_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_IN=30
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=1000
LOG_LEVEL=info
# Pretty logs (needs `pino-pretty`, installed via devDependencies). Use false for production Docker images.
LOG_PRETTY=true
COMPANY_NAME=PING

# Optional SMTP settings. Email helpers no-op when these are absent.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=false
EMAIL_TLS_REJECT_UNAUTHORIZED=true
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FROM=

# Remote VPS health monitor (HTTPS probe + email alerts)
MONITOR_ENABLED=true
MONITOR_URL=https://api.jahbyte.com/api/v1/health
# Every quarter-hour at :00, :15, :30, :45 (server local time unless MONITOR_CRON_TIMEZONE is set)
MONITOR_CRON=*/2 * * * *
# MONITOR_CRON_TIMEZONE=UTC
MONITOR_TIMEOUT_MS=10000
MONITOR_FAILURE_THRESHOLD=3
MONITOR_ALERT_COOLDOWN_MS=900000
ALERT_EMAIL=you@example.com
