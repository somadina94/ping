NODE_ENV=development
PORT=3000

DATABASE=mongodb://localhost:27017/ping
# DOCKER_DATABASE=mongodb://mongo:27017/ping
DATABASE_PASSWORD=

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=false
EMAIL_TLS_REJECT_UNAUTHORIZED=true
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FROM=

MONITOR_ENABLED=true
MONITOR_URL=https://api.jahbyte.com/api/v1/health
MONITOR_CRON=*/2 * * * *
# MONITOR_CRON_TIMEZONE=UTC
MONITOR_NOTIFY_ON_SUCCESS=true
MONITOR_TIMEOUT_MS=10000
MONITOR_FAILURE_THRESHOLD=1
MONITOR_ALERT_COOLDOWN_MS=900000
ALERT_EMAIL=you@example.com
